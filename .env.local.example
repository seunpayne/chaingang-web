# Chaingang Cycling Club Abuja — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Strava API (Required for leaderboard)
STRAVA_CLIENT_ID=12345
STRAVA_CLIENT_SECRET=abc123def456
STRAVA_REFRESH_TOKEN=abc123def456ghi789
STRAVA_CLUB_ID=12345

# Instagram Basic Display (Required for gallery embed)
INSTAGRAM_ACCESS_TOKEN=IGQVJ...

# Resend (Required for contact form + invite emails)
RESEND_API_KEY=re_abc123...

# Cron Secret (Required for scheduled jobs)
CRON_SECRET=random-secret-string-here

# Twilio WhatsApp (Optional — for urgent announcement push)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=abc123...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
CHAINGANG_WHATSAPP_GROUP=whatsapp:+2347066399546

# Telegram Bot (Optional — for alerts)
TELEGRAM_BOT_TOKEN=123:abc
TELEGRAM_CHAT_ID=12345

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
